# Copy to `.env` and fill in real values. Never commit `.env`.

# Streamlit-authenticator cookie signing key. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
COOKIE_KEY=change-me-to-a-long-random-hex-string
COOKIE_NAME=ic_dashboard_auth
COOKIE_EXPIRY_DAYS=7

# Timezone used inside the Docker containers.
TZ=Asia/Taipei
